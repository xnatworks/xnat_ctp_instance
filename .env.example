# CTP Configuration
CTP_DICOM_PORT=1085
CTP_HTTP_PORT=1080

# XNAT Target - HTTP Export
# Use container name for internal docker network access
XNAT_URL=http://xnat-nginx
XNAT_USERNAME=admin
XNAT_PASSWORD=changeme
# Destination: /prearchive sends to prearchive, or specify a project ID
XNAT_PROJECT=/prearchive
